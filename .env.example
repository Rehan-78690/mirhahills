# =============================================================================
# Mira Hills — Environment Variables (EXAMPLE)
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets to version control.
# =============================================================================

# ---- Email provider selection ----------------------------------------------
# One of: smtp | resend | sendgrid
# We use Zoho Mail, which is SMTP-based, so keep this as "smtp".
EMAIL_PROVIDER=smtp

# ---- Shared email identity (all providers) ----------------------------------
# Where inquiry notifications are delivered.
CONTACT_TO=info@dubaihaus.com
# The "From" header. Use a mailbox you control on your Zoho domain.
CONTACT_FROM="Mira Hills <info@dubaihaus.com>"

# ---- SMTP (Zoho Mail) -------------------------------------------------------
# Zoho SMTP host:
#   - Personal @zoho.com accounts:        smtp.zoho.com
#   - Custom-domain / organisation mail:  smtppro.zoho.com
#   - EU data centre:                     smtp.zoho.eu
# Port 465 with SSL is recommended. (Alt: 587 with SMTP_SECURE=false for STARTTLS.)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@dubaihaus.com
# Generate an app-specific password in Zoho:
# Settings -> Security -> App Passwords (required if 2FA is enabled).
SMTP_PASS=

# ---- API providers (only needed if EMAIL_PROVIDER is set to one of these) ----
# Resend  (EMAIL_PROVIDER=resend)
RESEND_API_KEY=
# SendGrid (EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
