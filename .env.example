# =============================================================================
# Mira Hills — Environment Variables (EXAMPLE)
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets to version control.
# =============================================================================

# ---- Email provider selection ----------------------------------------------
# One of: smtp | resend | sendgrid
# We use Zoho Mail, which is SMTP-based, so keep this as "smtp".
EMAIL_PROVIDER=smtp

# ---- Shared email identity (all providers) ----------------------------------
# Where inquiry notifications are delivered.
CONTACT_TO=info@mira-hills.com
# The "From" header. Use a mailbox you control on your Zoho domain.
CONTACT_FROM="Mira Hills <info@mira-hills.com>"

# ---- SMTP (Zoho Mail) -------------------------------------------------------
# Zoho SMTP host:
#   - Personal @zoho.com accounts:        smtp.zoho.com
#   - Custom-domain / organisation mail:  smtppro.zoho.com
#   - EU data centre:                     smtp.zoho.eu
# Port 465 with SSL is recommended. (Alt: 587 with SMTP_SECURE=false for STARTTLS.)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@mira-hills.com
# Generate an app-specific password in Zoho:
# Settings -> Security -> App Passwords (required if 2FA is enabled).
SMTP_PASS=

# ---- API providers (only needed if EMAIL_PROVIDER is set to one of these) ----
# Resend  (EMAIL_PROVIDER=resend)
RESEND_API_KEY=
# SendGrid (EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# ---- Lead storage (MongoDB) -------------------------------------------------
# Where enquiry / brochure / contact submissions are persisted.
#   - SET on serverless hosts (Vercel): the filesystem is ephemeral there, so a
#     database is required or leads are lost.
#   - LEAVE BLANK for local dev / self-hosted `next start`: leads then append to
#     data/leads.jsonl automatically (no database needed).
# Atlas free tier (M0) works well. Allow network access from 0.0.0.0/0 since
# Vercel IPs are dynamic. Example:
#   mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Optional database name (defaults to "mira_hills").
MONGODB_DB=mira_hills

# ---- Admin panel (/admin-secure-mira) ---------------------------------------
# Password to sign in to the admin panel where enquiries + brochure requests
# are listed. Required for the admin panel to be usable.
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie. Use a long random string.
# (Generate one with: openssl rand -hex 32)
ADMIN_SESSION_SECRET=
